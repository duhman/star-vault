{
  "name": "star-vault",
  "version": "1.0.0",
  "description": "GitHub Stars Intelligence System - semantic search over starred repositories",
  "type": "module",
  "packageManager": "bun@1.2.22",
  "scripts": {
    "import": "bun run src/index.ts import",
    "fetch-content": "bun run src/index.ts fetch-content",
    "embeddings": "bun run src/index.ts embeddings",
    "sync": "bun run src/index.ts sync",
    "reconcile": "bun run src/index.ts reconcile",
    "verify": "bun run src/index.ts verify",
    "stats": "bun run src/index.ts stats",
    "mcp": "bun run mcp-server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "deploy:cron": "supabase functions deploy sync-stars sync-content sync-embeddings sync-reconcile",
    "deploy:gpt": "supabase functions deploy sync-embeddings",
    "deploy:util": "supabase functions deploy sync-stars sync-content sync-reconcile"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2",
    "openai": "^4.104.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "hono": ">=4.12.26",
    "fast-uri": ">=3.1.2",
    "ws": ">=8.20.1",
    "qs": ">=6.15.2"
  }
}
