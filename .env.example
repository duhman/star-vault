# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
# Use service role key (not anon key) because sync performs writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Canonical schema for this project:
SUPABASE_SCHEMA=star_vault

# OpenAI for embeddings by default
OPENAI_API_KEY=sk-your-openai-key
# Optional: use Gemini embeddings instead. Defaults to OpenAI.
# EMBEDDING_PROVIDER=openai
# GEMINI_API_KEY=your-gemini-key

# Optional: content is rechecked when last checked >= this many days ago.
# CONTENT_STALE_DAYS=30

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes:
# - public stars: read:user
# - private repos stars/content (if needed): repo
GITHUB_TOKEN=github_pat_your-token
